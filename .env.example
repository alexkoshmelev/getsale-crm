# =============================================================================
# GetSale CRM — Environment Variables
# Copy to .env and fill in production values before deploying.
# The defaults below match docker-compose.yml dev values.
# Host ports: Postgres 5433, Redis 6380 (see docker-compose.yml) so local 5432/6379 stay free.
# =============================================================================

# --- Infrastructure ---
POSTGRES_PASSWORD=postgres_dev
REDIS_PASSWORD=redis_dev
# When running services on the host against `docker compose up postgres redis`:
# DATABASE_URL=postgresql://postgres:postgres_dev@localhost:5433/postgres
# REDIS_URL=redis://:redis_dev@localhost:6380

# --- Auth / Secrets (MUST change in production) ---
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
INTERNAL_AUTH_SECRET=dev_internal_auth_secret
SESSION_ENCRYPTION_KEY=dev_session_encryption_key_change_in_production

# --- Telegram ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
CAMPAIGN_MAX_SENDS_PER_ACCOUNT_PER_DAY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI ---
OPENAI_API_KEY=
# For campaign message rephrase (ai-service). Campaign-service also needs AI_SERVICE_URL (set in docker-compose).
OPENROUTER_API_KEY=
# Default in code/docker: google/gemma-3-27b-it:free (stable instruct). Optional: openrouter/free (pool may pick "thinking" models).
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_MS=55000

# --- Frontend ---
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:3004
