# =============================================================================
# GetSale CRM — Environment Variables
# Copy to .env and fill in production values before deploying.
# The defaults below match docker-compose.yml dev values.
# Host ports: Postgres 5433, Redis 6380 (see docker-compose.yml) so local 5432/6379 stay free.
# =============================================================================

# --- Infrastructure ---
POSTGRES_PASSWORD=postgres_dev
REDIS_PASSWORD=redis_dev
# When running services on the host against `docker compose up postgres redis`:
# DATABASE_URL=postgresql://postgres:postgres_dev@localhost:5433/postgres
# REDIS_URL=redis://:redis_dev@localhost:6380

# --- Auth / Secrets (MUST change in production) ---
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
INTERNAL_AUTH_SECRET=dev_internal_auth_secret
SESSION_ENCRYPTION_KEY=dev_session_encryption_key_change_in_production

# --- Public dev URL / cookies (auth-service + gateway + websocket) ---
# app.getsale.ai (prod) and dev-app.getsale.ai (dev) share .getsale.ai — prod cookies (Domain=.getsale.ai)
# would be sent to dev and cause JWT "invalid signature" if names and secrets differ.
# - Use different cookie names on dev (defaults in docker-compose: access_token_dev / refresh_token_dev).
# - COOKIE_DOMAIN: leave empty for host-only cookies on the tunnel host (recommended for dev-app).
#   Do NOT use COOKIE_DOMAIN=localhost for a tunnel — Set-Cookie may be rejected; prod cookies can win.
# - Optional: COOKIE_DOMAIN=.getsale.ai when API is on a separate host and must share cookies (prod pattern).
AUTH_COOKIE_ACCESS=access_token_dev
AUTH_COOKIE_REFRESH=refresh_token_dev
COOKIE_DOMAIN=

# --- Telegram ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# bd-accounts-service: GramJS keepalive interval (ms); default 15000 — helps SOCKS5 idle timeouts
# TELEGRAM_KEEPALIVE_INTERVAL_MS=15000
# Cap for FLOOD_WAIT sleep / persistence (seconds); default 600
# TELEGRAM_FLOOD_WAIT_CAP_SECONDS=600
CAMPAIGN_MAX_SENDS_PER_ACCOUNT_PER_DAY=
# campaign-service: min ms between two campaign sends from same BD account in one worker batch (default 360000 ≈ 6 min; set 0 to disable)
# CAMPAIGN_MIN_GAP_MS_SAME_BD_ACCOUNT=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI ---
OPENAI_API_KEY=
# For campaign message rephrase (ai-service). Campaign-service also needs AI_SERVICE_URL (set in docker-compose).
OPENROUTER_API_KEY=
# Per-feature models. Legacy OPENROUTER_MODEL applies only where a feature-specific var is empty.
# Локально можно не задавать — в коде свои дефолты. Для production с docker-compose.server.yml заданы дефолты в compose (пресет + free Gemma).
OPENROUTER_CAMPAIGN_MODEL=@preset/copyright
OPENROUTER_AUTO_RESPOND_MODEL=google/gemma-3-27b-it:free
OPENROUTER_CHAT_SUMMARIZE_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_MODEL=
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_MS=55000

# --- Frontend / CORS (api-gateway; docker-compose default includes tunnel dev-app) ---
# Comma-separated origins. Add https://dev-app.getsale.ai when using a tunnel to local Docker.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://dev-app.getsale.ai
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:3004
