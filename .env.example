# =============================================================================
# GetSale CRM — environment template
#
# Usage:
#   cp .env.example .env
#   Edit .env (never commit real secrets).
#
# This file has two blocks:
#   §1 — Local development (docker-compose.yml, services on host optional)
#   §2 — Production server (docker-compose.server.yml) — strong passwords/secrets
#
# On the server, copy only the variables you need from §2 (and optional RUN_SEEDS).
# =============================================================================

# =============================================================================
# §1 — LOCAL DEVELOPMENT (docker-compose.yml)
# =============================================================================
# Host ports (dev offsets): Postgres 5434, Redis 6381, RabbitMQ 5673 (AMQP), 15673 (UI).
# Gateway: http://localhost:8000  ·  Frontend dev: http://localhost:5173

# --- Infrastructure (defaults match compose) ---
POSTGRES_PASSWORD=postgres_dev
# From host (migrations, psql): use port 5434
# DATABASE_URL=postgresql://postgres:postgres_dev@localhost:5434/postgres

# Redis: compose uses redis:6379 inside the network; no password in default compose.
# From host:
# REDIS_URL=redis://localhost:6381

# RabbitMQ (full URL for tools on host; compose builds URLs for containers)
RABBITMQ_URL=amqp://getsale:getsale_dev@localhost:5673

# --- Auth / secrets (change for anything exposed beyond localhost) ---
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
INTERNAL_AUTH_SECRET=dev_internal_auth_secret
SESSION_ENCRYPTION_KEY=dev_session_encryption_key_change_in_production

# --- Cookies (auth + gateway + notification-hub) ---
# Dev: different cookie names avoid clashes with prod on shared parent domain.
AUTH_COOKIE_ACCESS=access_token_dev
AUTH_COOKIE_REFRESH=refresh_token_dev
COOKIE_DOMAIN=

# --- Telegram (telegram-sm, discovery) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_KEEPALIVE_INTERVAL_MS=15000
# TELEGRAM_FLOOD_WAIT_CAP_SECONDS=600

# --- Campaign / inter-service HTTP (optional overrides) ---
CAMPAIGN_MAX_SENDS_PER_ACCOUNT_PER_DAY=
# CAMPAIGN_MIN_GAP_MS_SAME_BD_ACCOUNT=
CAMPAIGN_MESSAGING_HTTP_TIMEOUT_MS=150000
MESSAGING_BD_ACCOUNTS_HTTP_TIMEOUT_MS=120000
CAMPAIGN_BD_ACCOUNTS_HTTP_TIMEOUT_MS=90000

# --- Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_CAMPAIGN_MODEL=@preset/copyright
OPENROUTER_AUTO_RESPOND_MODEL=google/gemma-3-27b-it:free
OPENROUTER_CHAT_SUMMARIZE_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_MODEL=
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_MS=55000

# --- Frontend / CORS (gateway + Next) ---
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://dev-app.getsale.ai
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:4008

# --- Local dev meta ---
NODE_ENV=development

# Observability — Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# §2 — PRODUCTION SERVER (docker-compose.server.yml)
# =============================================================================
# Copy these to .env next to docker-compose.server.yml on the server.
# Required: POSTGRES_PASSWORD, REDIS_PASSWORD, RABBITMQ_PASSWORD, JWT_SECRET,
# JWT_REFRESH_SECRET, INTERNAL_AUTH_SECRET. Compose builds RABBITMQ_URL from password.

# Optional: demo seeds after migrate (migrations service). Default skips seeds in production.
# RUN_SEEDS=true

# --- Database ---
# POSTGRES_PASSWORD=your_strong_postgres_password
# Host publish: docker-compose.server.yml maps Postgres to 127.0.0.1:5435 only (not on the public interface).
# From home use SSH: ssh -N -L 5435:127.0.0.1:5435 user@server then connect to localhost:5435. See docs/operations/DEPLOYMENT.md.

# --- Redis ---
# REDIS_PASSWORD=your_strong_redis_password

# --- RabbitMQ (password for user "getsale") ---
# RABBITMQ_PASSWORD=your_strong_rabbitmq_password

# --- JWT ---
# JWT_SECRET=your_jwt_secret_min_32_chars
# JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars

# --- Internal auth (gateway → backends; openssl rand -hex 32) ---
# INTERNAL_AUTH_SECRET=your_internal_auth_secret_min_32_chars

# --- CORS & cookies ---
# CORS_ORIGIN=https://app.getsale.ai
# COOKIE_DOMAIN=.getsale.ai
# AUTH_COOKIE_ACCESS=access_token
# AUTH_COOKIE_REFRESH=refresh_token

# --- URLs (user-service, links) ---
# FRONTEND_URL=https://app.getsale.ai
# PUBLIC_API_BASE_URL=https://api-crm.getsale.ai

# --- Telegram ---
# TELEGRAM_API_ID=12345
# TELEGRAM_API_HASH=your_api_hash_here
# SESSION_ENCRYPTION_KEY=your_32_byte_hex_or_long_passphrase

# --- OpenAI / OpenRouter ---
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=
# OPENROUTER_CAMPAIGN_MODEL=@preset/copyright
# OPENROUTER_AUTO_RESPOND_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_CHAT_SUMMARIZE_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_MODEL=
# OPENROUTER_MAX_TOKENS=2048
# OPENROUTER_TIMEOUT_MS=55000

# --- Stripe ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_CREDITS_SMALL=
# STRIPE_PRICE_CREDITS_MEDIUM=
# STRIPE_PRICE_CREDITS_LARGE=

# --- NOWPayments ---
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_PAY_CURRENCY=usdtbsc

# --- Workers ---
# WORKER_CONCURRENCY=1

# --- Registry (optional) ---
# REGISTRY=registry.digitalocean.com/regestry-getsale-ai

# --- Environment ---
# NODE_ENV=production
