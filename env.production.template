# =============================================================================
# GetSale CRM — production .env (полный шаблон)
#
# Скопируйте в каталог с docker-compose на сервере как `.env`:
#   cp env.production.template .env
# Замените все значения `__PASTE_*__` на свои (секреты, пароли, ключи).
# Не коммитьте реальный `.env`.
#
# Запуск:
#   docker compose -f docker-compose.server.yml -f docker-compose.observability.prod.yml up -d
#
# RABBITMQ_URL в compose не задаётся: URL собирается из RABBITMQ_PASSWORD и хоста rabbitmq.
# RabbitMQ в docker-compose.server.yml не публикует порты наружу (только внутри сети).
# =============================================================================

# --- Docker / образы (опционально) ---
NODE_ENV=production
REGISTRY=registry.digitalocean.com/regestry-getsale-ai
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7-alpine
WORKER_CONCURRENCY=1

# --- Инфраструктура: пароли (обязательно) ---
POSTGRES_PASSWORD=__PASTE_POSTGRES_PASSWORD__
REDIS_PASSWORD=__PASTE_REDIS_PASSWORD__
RABBITMQ_PASSWORD=__PASTE_RABBITMQ_PASSWORD__

# --- JWT и межсервисная авторизация (обязательно) ---
# openssl rand -hex 32 — для INTERNAL_AUTH_SECRET и при желании для JWT
JWT_SECRET=__PASTE_JWT_SECRET_MIN_32_CHARS__
JWT_REFRESH_SECRET=__PASTE_JWT_REFRESH_SECRET_MIN_32_CHARS__
INTERNAL_AUTH_SECRET=__PASTE_INTERNAL_AUTH_SECRET__

# --- CORS, cookies, публичные URL (домены под ваш прод) ---
CORS_ORIGIN=https://app.getsale.ai
FRONTEND_URL=https://app.getsale.ai
COOKIE_DOMAIN=.getsale.ai
AUTH_COOKIE_ACCESS=access_token
AUTH_COOKIE_REFRESH=refresh_token
PUBLIC_API_BASE_URL=https://api-crm.getsale.ai

# --- Telegram (telegram-sm: сессии MTProto) ---
TELEGRAM_API_ID=__PASTE_TELEGRAM_API_ID__
TELEGRAM_API_HASH=__PASTE_TELEGRAM_API_HASH__
SESSION_ENCRYPTION_KEY=__PASTE_SESSION_ENCRYPTION_KEY__

# --- AI (кампании, автоответы; оставьте пустым, если не используете) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_CAMPAIGN_MODEL=@preset/copyright
OPENROUTER_AUTO_RESPOND_MODEL=google/gemma-3-27b-it:free
OPENROUTER_CHAT_SUMMARIZE_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MODEL=
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_MS=55000

# --- Billing (опционально) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREDITS_SMALL=
STRIPE_PRICE_CREDITS_MEDIUM=
STRIPE_PRICE_CREDITS_LARGE=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdtbsc

# --- Observability (docker-compose.observability.prod.yml) ---
GRAFANA_HOST=grafana-app.getsale.ai
GRAFANA_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=__PASTE_GRAFANA_ADMIN_PASSWORD__
TELEGRAM_BOT_TOKEN=__PASTE_TELEGRAM_BOT_TOKEN__
TELEGRAM_CHAT_ID=__PASTE_TELEGRAM_CHAT_ID__

# --- Миграции (по умолчанию сиды в проде не грузятся) ---
# RUN_SEEDS=true

# =============================================================================
# Для подключения с хоста к Postgres (после SSH-туннеля на 127.0.0.1:5435):
#   postgresql://postgres:<тот же POSTGRES_PASSWORD>@127.0.0.1:5435/postgres
# =============================================================================
