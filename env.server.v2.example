# ============================================================
# Production .env for SERVER (docker-compose.server.v2.yml)
# Copy to .env on server: cp env.server.v2.example .env
# Do NOT commit real .env with secrets to git.
#
# Required: POSTGRES_PASSWORD, REDIS_PASSWORD, RABBITMQ_PASSWORD, JWT_SECRET,
# JWT_REFRESH_SECRET, INTERNAL_AUTH_SECRET. Without these, docker compose shows
# warnings and services may fail.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Use strong password in production. Shared by postgres & pgbouncer.
POSTGRES_PASSWORD=your_strong_postgres_password

# ─── Redis ───────────────────────────────────────────────────
# Use strong password in production. All services connect via
# redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=your_strong_redis_password

# ─── RabbitMQ ────────────────────────────────────────────────
# Password for user "getsale". docker-compose builds
# RABBITMQ_URL=amqp://getsale:${RABBITMQ_PASSWORD}@rabbitmq:5672 for all services.
RABBITMQ_PASSWORD=your_strong_rabbitmq_password

# ─── JWT ─────────────────────────────────────────────────────
# Generate strong random secrets: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars

# ─── Internal Auth ───────────────────────────────────────────
# Gateway → backends shared secret. Same value on gateway and all backend services.
# Generate: openssl rand -hex 32
INTERNAL_AUTH_SECRET=your_internal_auth_secret_min_32_chars

# ─── CORS & Cookies ─────────────────────────────────────────
# Frontend origin for CORS and WebSocket. Must match frontend domain.
CORS_ORIGIN=https://app.getsale.ai

# Shared cookie domain so auth tokens are sent to ws-crm.getsale.ai
COOKIE_DOMAIN=.getsale.ai

# Cookie names for access/refresh tokens (change if running multiple envs on same domain)
AUTH_COOKIE_ACCESS=access_token
AUTH_COOKIE_REFRESH=refresh_token

# ─── Frontend & API URLs ────────────────────────────────────
# Used by user-service for redirects and email links
FRONTEND_URL=https://app.getsale.ai
PUBLIC_API_BASE_URL=https://api-crm.getsale.ai

# ─── Telegram API ───────────────────────────────────────────
# Required for telegram-sm (Telegram session management).
# Obtain at https://my.telegram.org/apps
# Option 1: Set as GitHub Actions secrets (written to .env on deploy).
# Option 2: Set directly in .env on server, then:
#   docker compose -f docker-compose.server.v2.yml up -d --force-recreate telegram-sm
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash_here

# Session encryption key for Telegram account sessions.
# Must be consistent across deploys; changing it invalidates encrypted sessions.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=your_32_byte_hex_or_long_passphrase

# ─── OpenAI (optional) ──────────────────────────────────────
# Leave empty to disable OpenAI-powered features
OPENAI_API_KEY=sk-...

# ─── OpenRouter (optional) ──────────────────────────────────
# Required for campaign rephrase and any OpenRouter-routed AI features
OPENROUTER_API_KEY=

# Per-feature models (override defaults below as needed)
# Do NOT use a single OPENROUTER_MODEL for all — each feature may need a different model
OPENROUTER_CAMPAIGN_MODEL=@preset/copyright
OPENROUTER_AUTO_RESPOND_MODEL=google/gemma-3-27b-it:free
OPENROUTER_CHAT_SUMMARIZE_MODEL=google/gemma-3-27b-it:free

# Legacy fallback model (leave empty if per-feature models are set above)
OPENROUTER_MODEL=
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_MS=55000

# ─── Stripe (optional) ──────────────────────────────────────
# Leave empty if not using Stripe billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for credit packs
STRIPE_PRICE_CREDITS_SMALL=
STRIPE_PRICE_CREDITS_MEDIUM=
STRIPE_PRICE_CREDITS_LARGE=

# ─── NOWPayments (optional) ─────────────────────────────────
# Crypto payment gateway. Leave empty to disable.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PAY_CURRENCY=usdtbsc

# ─── Workers ────────────────────────────────────────────────
# Campaign worker concurrency (number of parallel message sends per worker instance)
WORKER_CONCURRENCY=1

# ─── Registry (optional) ────────────────────────────────────
# Override the default DigitalOcean registry
# REGISTRY=registry.digitalocean.com/regestry-getsale-ai

# ─── Environment ────────────────────────────────────────────
NODE_ENV=production
