# Development Dockerfile for backend services (monorepo). Shared for all services via SERVICE_PATH.
# Build context: repo root. Example: docker build -f docker/services/Dockerfile.dev --build-arg SERVICE_PATH=services/api-gateway .
FROM node:22-alpine

ARG SERVICE_PATH=services/api-gateway

WORKDIR /app

# Copy root package files for workspaces
COPY package*.json ./

# Copy shared packages (types, events, logger moved to shared-v2/ during v1→v2 migration)
COPY shared/ ./shared/
COPY shared-v2/ ./shared-v2/

# Copy service package.json
COPY ${SERVICE_PATH}/package*.json ./${SERVICE_PATH}/

# Install all dependencies (workspaces will resolve local packages)
RUN npm install

# Build shared packages in dependency order: types -> events -> logger (now in shared-v2/) -> utils -> service-core
RUN npm run build --workspace=shared-v2/types && \
    npm run build --workspace=shared-v2/events && \
    npm run build --workspace=shared-v2/logger && \
    npm run build --workspace=shared/utils && \
    npm run build --workspace=shared/service-core

# Copy service source code
COPY ${SERVICE_PATH}/ ./${SERVICE_PATH}/

# Copy entrypoint script (from repo root); normalize line endings (CRLF -> LF) for Linux
COPY docker-entrypoint.sh /usr/local/bin/
RUN sed 's/\r$//' /usr/local/bin/docker-entrypoint.sh > /tmp/ep && mv /tmp/ep /usr/local/bin/docker-entrypoint.sh && chmod +x /usr/local/bin/docker-entrypoint.sh

RUN addgroup -g 1001 -S appgroup && adduser -u 1001 -S appuser -G appgroup
RUN chown -R appuser:appgroup /app

WORKDIR /app/${SERVICE_PATH}
USER appuser

EXPOSE 8000

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
