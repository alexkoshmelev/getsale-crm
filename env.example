# Database
POSTGRES_PASSWORD=postgres_dev
DATABASE_URL=postgresql://postgres:postgres_dev@localhost:5433/postgres

# Redis
REDIS_PASSWORD=redis_dev
REDIS_URL=redis://:redis_dev@localhost:6380

# RabbitMQ (local dev: full URL; server: use env.server.example and set RABBITMQ_PASSWORD only)
RABBITMQ_URL=amqp://getsale:getsale_dev@localhost:5672

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production

# Internal auth: gateway sends this header to backends; backends reject requests without it when set (prevents bypass).
# Leave empty for local dev without gateway; set same value on gateway and all backends in production.
# INTERNAL_AUTH_SECRET=

# OpenAI API (get a key at https://platform.openai.com/account/api-keys)
# Leave empty to disable AI draft generation; use a real sk-... key to enable.
OPENAI_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram API (BD Accounts — подключение аккаунтов; получить на https://my.telegram.org/apps)
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash_here

# Синхронизация: при начальной синхронизации грузится только одна «страница» на чат; старые сообщения догружаются при скролле вверх в Messaging
# SYNC_INITIAL_MESSAGES_PER_CHAT=100   — сообщений на чат при старте (по умолчанию 100)
# SYNC_MESSAGES_PER_CHAT_CAP=50000     — макс. сообщений на чат при догрузке по скроллу

# CORS (comma-separated; in dev, localhost/127.0.0.1 are reflected so e.g. :3000 and :5173 both work)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# FRONTEND_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development

